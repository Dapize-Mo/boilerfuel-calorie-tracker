# Base URL of the Flask backend API
NEXT_PUBLIC_API_URL=http://127.0.0.1:5000

# Google OAuth Credentials
# Get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# NextAuth Configuration
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Admin password required for /api/admin/login
ADMIN_PASSWORD=change-me

# JWT secret for signing admin tokens (defaults to ADMIN_PASSWORD if unset)
# JWT_SECRET_KEY=some-long-random-string

# Database connection (set on Vercel for production)
# POSTGRES_URL=postgresql://user:password@host:port/dbname
